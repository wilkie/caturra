{
  "name": "@caturra/sandbox",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-origin sandbox host: runs the caturra engine inside an iframe so the editor origin's session data stays isolated",
  "type": "module",
  "scripts": {
    "dev": "VITE_EDITOR_ORIGINS=http://localhost:5173 vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "echo \"covered by root test:e2e (Playwright)\""
  },
  "dependencies": {
    "@caturra/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
