{
  "name": "caturra",
  "version": "0.1.0",
  "private": true,
  "description": "A JVM (compiler + runtime) for the CSA subset of Java 11, in Rust compiled to WASM, for backend-free use in the browser",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build:wasm": "wasm-pack build crates/caturra-wasm --target web --out-dir ../../packages/core/src/wasm/generated --out-name caturra --no-pack",
    "sounds:fetch": "python3 apps/playground/scripts/fetch-sounds.py",
    "build": "pnpm build:wasm && pnpm -r build",
    "dev": "pnpm --filter @caturra/playground dev",
    "dev:sandbox": "pnpm --filter @caturra/sandbox dev",
    "dev:isolated": "pnpm --parallel --filter @caturra/playground --filter @caturra/sandbox dev",
    "test": "pnpm -r test",
    "test:rust": "cargo test --workspace",
    "test:e2e": "playwright test",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "lint:rust": "cargo clippy --workspace --all-targets && cargo fmt --check",
    "deploy:pages": "bash scripts/deploy-pages.sh"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@playwright/test": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "wasm-pack": "catalog:"
  }
}
